// ============================================================
// HR & Payroll SaaS — Prisma Schema
// Database: PostgreSQL
// ============================================================

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum EmployeeStatus {
    ACTIVE
    ON_LEAVE
    TERMINATED
}

enum UserRole {
    HR_ADMIN // Can run payroll, manage all employees
    MANAGER // Can approve advances, view their team
    EMPLOYEE // Can clock in/out, request advances
}

enum AdvanceStatus {
    PENDING
    APPROVED
    REJECTED
}

enum PayrollRunStatus {
    PENDING // Created, not yet picked up by the queue
    PROCESSING // BullMQ worker is actively computing payslips
    DONE // All payslips generated successfully
    FAILED // Something went wrong — check logs
}

// ============================================================
// COMPANIES
// The root of multi-tenancy. Every other record traces
// back to a company via company_id.
// ============================================================

model Company {
    id        String   @id @default(cuid())
    name      String
    taxId     String   @unique // Egyptian Tax Authority registration number
    industry  String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    departments Department[]
    employees   Employee[]
    locations   OfficeLocation[]
    payrollRuns PayrollRun[]

    @@map("companies")
}

// ============================================================
// DEPARTMENTS
// Belongs to a company. Has an optional manager (an Employee).
// Note: manager_id is nullable because when you first create
// a department, you might not have assigned a manager yet.
// ============================================================

model Department {
    id        String  @id @default(cuid())
    companyId String
    name      String
    managerId String? // FK → Employee (nullable)

    // Relations
    company   Company    @relation(fields: [companyId], references: [id])
    manager   Employee?  @relation("DepartmentManager", fields: [managerId], references: [id])
    employees Employee[] @relation("DepartmentEmployees")

    @@map("departments")
}

// ============================================================
// EMPLOYEES
// The core HR entity. Holds personal + payroll-relevant data.
// Separated from Users intentionally — not every employee
// needs a login account (e.g. factory floor workers).
// ============================================================

model Employee {
    id           String         @id @default(cuid())
    companyId    String
    departmentId String?
    name         String
    nationalId   String         @unique // Egyptian National ID (14 digits)
    grossSalary  Decimal        @db.Decimal(12, 2)
    netSalary    Decimal        @db.Decimal(12, 2)
    jobTitle     String?
    hireDate     DateTime       @db.Date
    status       EmployeeStatus @default(ACTIVE)
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt

    // Relations
    company    Company     @relation(fields: [companyId], references: [id])
    department Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])

    // Self-referential: this employee might manage a department
    managedDepartments Department[] @relation("DepartmentManager")

    // Account, attendance, advances, payslips
    user        User?
    attendances Attendance[]
    advances    Advance[]    @relation("EmployeeAdvances")
    payslips    Payslip[]

    // Advances this employee has approved (as a manager)
    approvedAdvances Advance[] @relation("AdvanceApprover")

    // Payroll runs this employee has triggered (as HR admin)
    triggeredPayrollRuns PayrollRun[]

    @@index([companyId]) // Always filter by company first
    @@index([nationalId])
    @@map("employees")
}

// ============================================================
// USERS
// Login accounts. Separate from Employee on purpose.
// role determines what they can see and do in the API.
// ============================================================

model User {
    id           String    @id @default(cuid())
    employeeId   String    @unique // One account per employee
    email        String    @unique
    passwordHash String
    role         UserRole  @default(EMPLOYEE)
    lastLoginAt  DateTime?
    createdAt    DateTime  @default(now())

    // Relations
    employee Employee @relation(fields: [employeeId], references: [id])

    @@map("users")
}

// ============================================================
// OFFICE LOCATIONS
// Each company can have multiple branches/offices.
// The geo-fence radius is stored here, not on Attendance.
// When an employee clocks in, your backend computes the
// distance between their GPS coords and this location's
// coords, then checks against fence_radius_m.
// ============================================================

model OfficeLocation {
    id           String @id @default(cuid())
    companyId    String
    name         String // e.g. "Cairo HQ", "Alexandria Branch"
    latitude     Float
    longitude    Float
    fenceRadiusM Int    @default(50) // meters, default 50m

    // Relations
    company     Company      @relation(fields: [companyId], references: [id])
    attendances Attendance[]

    @@map("office_locations")
}

// ============================================================
// ATTENDANCES
// One record per clock-in event.
// clock_out is nullable — employee hasn't clocked out yet.
// is_valid is computed by your backend using the Haversine
// formula against the linked OfficeLocation's fence.
// ============================================================

model Attendance {
    id         String    @id @default(cuid())
    employeeId String
    locationId String
    clockIn    DateTime
    clockOut   DateTime? // null until employee clocks out
    latitude   Float // where employee actually was
    longitude  Float
    isValid    Boolean   @default(false) // was geo-fence check passed?
    createdAt  DateTime  @default(now())

    // Relations
    employee Employee       @relation(fields: [employeeId], references: [id])
    location OfficeLocation @relation(fields: [locationId], references: [id])

    @@index([employeeId])
    @@index([clockIn]) // for monthly queries
    @@map("attendances")
}

// ============================================================
// ADVANCES (Salafa / سلفة)
// Employee requests a salary advance.
// Flow: PENDING → APPROVED or REJECTED (by a manager)
// When payroll runs, approved + undeducted advances are
// summed and subtracted from net salary. deductedIn tracks
// which payroll run finally deducted it.
// ============================================================

model Advance {
    id          String        @id @default(cuid())
    employeeId  String
    approvedBy  String? // FK → Employee (the manager); null until decided
    amount      Decimal       @db.Decimal(12, 2)
    reason      String?
    status      AdvanceStatus @default(PENDING)
    requestedAt DateTime      @default(now())
    decidedAt   DateTime? // when manager approved or rejected

    // Which payroll run deducted this? null = not yet deducted
    deductedInId String?

    // Relations
    employee   Employee    @relation("EmployeeAdvances", fields: [employeeId], references: [id])
    approver   Employee?   @relation("AdvanceApprover", fields: [approvedBy], references: [id])
    deductedIn PayrollRun? @relation(fields: [deductedInId], references: [id])

    @@index([employeeId])
    @@index([status])
    @@map("advances")
}

// ============================================================
// PAYROLL RUNS
// One run per company per month.
// HR triggers it → status becomes PENDING →
// BullMQ worker picks it up → PROCESSING →
// All payslips created → DONE (or FAILED).
// triggeredBy tracks which HR admin started the run.
// ============================================================

model PayrollRun {
    id          String           @id @default(cuid())
    companyId   String
    month       Int // 1–12
    year        Int
    status      PayrollRunStatus @default(PENDING)
    triggeredBy String // FK → Employee (the HR admin)
    createdAt   DateTime         @default(now())
    updatedAt   DateTime         @updatedAt

    // Relations
    company  Company   @relation(fields: [companyId], references: [id])
    trigger  Employee  @relation(fields: [triggeredBy], references: [id])
    payslips Payslip[]
    advances Advance[] // advances deducted in this run

    // A company can only have one run per month/year
    @@unique([companyId, month, year])
    @@index([companyId])
    @@map("payroll_runs")
}

// ============================================================
// PAYSLIPS
// The calculated output for one employee in one payroll run.
// Stores both employee AND employer insurance shares —
// you need the employer share for government form generation.
// All values are stored post-calculation (not recomputed).
// ============================================================

model Payslip {
    id           String @id @default(cuid())
    employeeId   String
    payrollRunId String

    // Salary breakdown (all in EGP)
    grossSalary       Decimal @db.Decimal(12, 2)
    taxDeduction      Decimal @db.Decimal(12, 2) // ETA progressive tax
    insuranceEmployee Decimal @db.Decimal(12, 2) // 11% — employee pays
    insuranceEmployer Decimal @db.Decimal(12, 2) // 18% — company pays (for forms)
    advanceDeduction  Decimal @db.Decimal(12, 2) // total salaf deducted this month
    netSalary         Decimal @db.Decimal(12, 2) // what hits the employee's account

    // Relations
    employee   Employee   @relation(fields: [employeeId], references: [id])
    payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])

    // One payslip per employee per run
    @@unique([employeeId, payrollRunId])
    @@index([payrollRunId])
    @@map("payslips")
}
